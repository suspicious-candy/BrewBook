MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/brewbook

# Server ports
PORT=5001
AUTH_SERVER_PORT=3000

# Frontend origin allowed by CORS
CLIENT_ORIGIN=https://localhost:5173
# Port the OAuth client (frontend) listens on — used to build the redirect URI
CLIENT_SERVER_PORT=5173

# RS256 key pair — generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Paste the full PEM content with literal \n newlines in the value.
PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Arbitrary identifier for the signing key (included in JWT header as kid)
KEY_ID=brewbook-key-1

# Authorization server identifier — set as the iss claim in every access token
ISSUER=https://auth.demo.com

# Resource server identifier — set as the aud claim in every access token;
# the resource server validates that aud matches this value on every request
RESOURCE_SERVER_AUDIENCE=https://api.demo.com

# Upstash Redis — used for rate limiting and OAuth token storage
UPSTASH_REDIS_REST_URL=https://<id>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<token>

# Supabase — used by the resource server to verify Bearer tokens
# The resource server fetches JWKS from {SUPABASE_URL}/auth/v1/.well-known/jwks.json
SUPABASE_URL=https://<project-ref>.supabase.co
# Optional: only set this if your Supabase project uses legacy HS256 keys.
# Find it in Supabase Studio → Project Settings → API → JWT Secret.
# SUPABASE_JWT_SECRET=
